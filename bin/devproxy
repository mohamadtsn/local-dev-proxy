#!/bin/bash
# bin/devproxy
# Main entry point for local-dev-proxy

set -e

# Determine script directory (resolve symlinks so lib/ is found correctly)
_REAL_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$_REAL_SCRIPT")" && pwd)"
BASE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
unset _REAL_SCRIPT

# Load configuration
if [[ -f "${BASE_DIR}/config/default.conf" ]]; then
    source "${BASE_DIR}/config/default.conf"
fi

# Load user configuration if exists
if [[ -f "$HOME/.local-dev-proxy.conf" ]]; then
    source "$HOME/.local-dev-proxy.conf"
fi

# Load libraries
for lib in "${LIB_DIR}"/*.sh; do
    if [[ -f "$lib" ]]; then
        source "$lib"
    fi
done

# Resolve a writable log file before any logging occurs.
# When installed as root, the default log path is owned by root.
_resolve_log_file

# Detect public-services ecosystem via docker inspect.
# If nginx-main has volume-mounted conf/ssl dirs, override CERT_DIR and
# SITE_ENABLED_DIR to those host paths so files are written there directly —
# no docker cp and no root required for config/cert management.
if is_docker_available 2>/dev/null; then
    if detect_ecosystem 2>/dev/null; then
        [[ -n "${ECOSYSTEM_SSL_DIR:-}" && -d "$ECOSYSTEM_SSL_DIR" ]] \
            && export CERT_DIR="$ECOSYSTEM_SSL_DIR"
        [[ -n "${ECOSYSTEM_CONF_DIR:-}" && -d "$ECOSYSTEM_CONF_DIR" ]] \
            && export SITE_ENABLED_DIR="$ECOSYSTEM_CONF_DIR"
    fi
fi

# Ensure required directories exist
ensure_directory "$CERT_DIR"
ensure_directory "$SITE_ENABLED_DIR"
ensure_directory "$TEMPLATE_DIR"
ensure_directory "$(dirname "$LOG_FILE")"

# Display usage information
usage() {
    local version
    version=$(cat "${BASE_DIR}/VERSION" 2>/dev/null || echo "dev")

    echo ""
    echo -e "  ${COLOR_CYAN}╭──────────────────────────────────────────────────────╮${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}│${COLOR_RESET}  ${COLOR_WHITE}devproxy${COLOR_RESET}  ${COLOR_DIM}·${COLOR_RESET}  Local Dev Proxy  ${COLOR_DIM}·${COLOR_RESET}  ${COLOR_YELLOW}v${version}${COLOR_RESET}           ${COLOR_CYAN}│${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}╰──────────────────────────────────────────────────────╯${COLOR_RESET}"
    echo ""
    echo -e "  ${COLOR_DIM}Usage:${COLOR_RESET}  devproxy ${COLOR_CYAN}<command>${COLOR_RESET} [options]"
    echo ""

    echo -e "  ${COLOR_BOLD}DOMAIN MANAGEMENT${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "    ${COLOR_CYAN}create${COLOR_RESET}              Create a new domain with configuration"
    echo -e "    ${COLOR_CYAN}remove${COLOR_RESET}              Remove a domain and its configuration"
    echo ""

    echo -e "  ${COLOR_BOLD}MAINTENANCE${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "    ${COLOR_CYAN}update${COLOR_RESET}              Check for updates and install if available"
    echo ""

    echo -e "  ${COLOR_BOLD}CERTIFICATES${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "    ${COLOR_CYAN}cert generate${COLOR_RESET}       Generate SSL certificate for a domain"
    echo -e "    ${COLOR_CYAN}cert remove${COLOR_RESET}         Remove SSL certificate"
    echo -e "    ${COLOR_CYAN}cert list${COLOR_RESET}           List all certificates"
    echo ""

    echo -e "  ${COLOR_BOLD}HOSTS FILE${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "    ${COLOR_CYAN}hosts add${COLOR_RESET}           Add entry to hosts file ${COLOR_YELLOW}(requires sudo)${COLOR_RESET}"
    echo -e "    ${COLOR_CYAN}hosts remove${COLOR_RESET}        Remove entry from hosts file ${COLOR_YELLOW}(requires sudo)${COLOR_RESET}"
    echo -e "    ${COLOR_CYAN}hosts list${COLOR_RESET}          List hosts file entries"
    echo ""

    echo -e "  ${COLOR_BOLD}NGINX${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "    ${COLOR_CYAN}nginx create-site${COLOR_RESET}   Create site configuration"
    echo -e "    ${COLOR_CYAN}nginx create-static${COLOR_RESET} Create static site configuration"
    echo -e "    ${COLOR_CYAN}nginx remove-site${COLOR_RESET}   Remove site configuration"
    echo -e "    ${COLOR_CYAN}nginx list${COLOR_RESET}          List all site configurations"
    echo -e "    ${COLOR_CYAN}nginx test${COLOR_RESET}          Test Nginx configuration"
    echo -e "    ${COLOR_CYAN}nginx reload${COLOR_RESET}        Reload Nginx"
    echo ""

    echo -e "  ${COLOR_BOLD}GENERAL${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "    ${COLOR_CYAN}mode${COLOR_RESET}                Show or change proxy mode"
    echo -e "    ${COLOR_CYAN}config${COLOR_RESET}              Show current configuration"
    echo -e "    ${COLOR_CYAN}completion${COLOR_RESET}          Output shell completion script"
    echo -e "    ${COLOR_CYAN}help${COLOR_RESET}                Show this help message"
    echo ""

    echo -e "  ${COLOR_BOLD}OPTIONS${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "    ${COLOR_CYAN}-h, --host${COLOR_RESET} DOMAIN       Domain name"
    echo -e "    ${COLOR_CYAN}-p, --port${COLOR_RESET} PORT         Port number"
    echo -e "    ${COLOR_CYAN}-i, --ip${COLOR_RESET} IP             IP address ${COLOR_DIM}(default: 127.0.0.1)${COLOR_RESET}"
    echo -e "    ${COLOR_CYAN}-s, --subdomain${COLOR_RESET}          Treat as subdomain ${COLOR_DIM}(requires -m)${COLOR_RESET}"
    echo -e "    ${COLOR_CYAN}-m, --main-domain${COLOR_RESET} DOMAIN Main domain for subdomain"
    echo -e "        ${COLOR_CYAN}--no-ssl${COLOR_RESET}             Disable SSL"
    echo -e "        ${COLOR_CYAN}--ssl${COLOR_RESET}                Enable SSL ${COLOR_DIM}(default)${COLOR_RESET}"
    echo -e "        ${COLOR_CYAN}--template${COLOR_RESET} PATH       Custom Nginx template"
    echo -e "        ${COLOR_CYAN}--mode${COLOR_RESET} MODE           Proxy mode: docker, local, auto"
    echo -e "        ${COLOR_CYAN}--static${COLOR_RESET}              Serve static files (no upstream proxy)"
    echo -e "        ${COLOR_CYAN}--root${COLOR_RESET} PATH           Document root for static sites"
    echo -e "        ${COLOR_CYAN}--name${COLOR_RESET} APP            App name shorthand: resolves to /srv/static/APP"
    echo -e "    ${COLOR_CYAN}-v, --version${COLOR_RESET}            Show version and exit"
    echo ""

    echo -e "  ${COLOR_BOLD}EXAMPLES${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "    ${COLOR_DIM}# Create domain with SSL${COLOR_RESET}"
    echo -e "    devproxy create ${COLOR_CYAN}-h myapp.local -p 3000${COLOR_RESET}"
    echo ""
    echo -e "    ${COLOR_DIM}# Create subdomain (shares cert with main domain)${COLOR_RESET}"
    echo -e "    devproxy create ${COLOR_CYAN}-h api.myapp.local -p 8080 -s -m myapp.local${COLOR_RESET}"
    echo ""
    echo -e "    ${COLOR_DIM}# Create static site (React/HTML build)${COLOR_RESET}"
    echo -e "    devproxy create ${COLOR_CYAN}-h myapp.local --static --root /var/www/myapp/dist${COLOR_RESET}"
    echo ""
    echo -e "    ${COLOR_DIM}# Create static site via app name (ecosystem mode: /srv/static/myapp)${COLOR_RESET}"
    echo -e "    devproxy create ${COLOR_CYAN}-h myapp.local --static --name myapp${COLOR_RESET}"
    echo ""
    echo -e "    ${COLOR_DIM}# Add to hosts file${COLOR_RESET}"
    echo -e "    sudo devproxy hosts add ${COLOR_CYAN}-h myapp.local${COLOR_RESET}"
    echo ""
    echo -e "    ${COLOR_DIM}# Switch to Docker mode${COLOR_RESET}"
    echo -e "    devproxy mode ${COLOR_CYAN}--mode docker${COLOR_RESET}"
    echo ""
    echo -e "  ${COLOR_DIM}https://github.com/mohamadtsn/local-dev-proxy${COLOR_RESET}"
    echo ""
}

# Parse command line arguments
parse_args() {
    COMMAND=""
    SUBCOMMAND=""
    HOST=""
    PORT=""
    IP="$DEFAULT_IP"
    IS_SUBDOMAIN=false
    MAIN_DOMAIN=""
    SSL_ENABLED="$DEFAULT_SSL_ENABLED"
    CUSTOM_TEMPLATE=""
    FORCE_MODE=""
    IS_STATIC=false
    STATIC_ROOT=""
    STATIC_APP_NAME=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            create|remove|update|cert|hosts|nginx|mode|config|completion|help)
                COMMAND="$1"
                shift
                if [[ -n "$1" ]] && [[ ! "$1" =~ ^- ]]; then
                    SUBCOMMAND="$1"
                    shift
                fi
                ;;
            -v|--version)
                cat "${BASE_DIR}/VERSION" 2>/dev/null || echo "dev"
                exit 0
                ;;
            -h|--host)
                HOST="$2"
                shift 2
                ;;
            -p|--port)
                PORT="$2"
                shift 2
                ;;
            -i|--ip)
                IP="$2"
                shift 2
                ;;
            -s|--subdomain)
                IS_SUBDOMAIN=true
                shift
                ;;
            -m|--main-domain)
                MAIN_DOMAIN="$2"
                shift 2
                ;;
            --no-ssl)
                SSL_ENABLED=false
                shift
                ;;
            --ssl)
                SSL_ENABLED=true
                shift
                ;;
            --template)
                CUSTOM_TEMPLATE="$2"
                shift 2
                ;;
            --mode)
                FORCE_MODE="$2"
                shift 2
                ;;
            --static)
                IS_STATIC=true
                shift
                ;;
            --root)
                STATIC_ROOT="$2"
                shift 2
                ;;
            --name)
                STATIC_APP_NAME="$2"
                shift 2
                ;;
            --help)
                usage
                exit 0
                ;;
            *)
                error "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
}

# Execute command
execute_command() {
    case "$COMMAND" in
        create)
            cmd_create_domain
            ;;
        remove)
            cmd_remove_domain
            ;;
        update)
            cmd_update
            ;;
        cert)
            cmd_certificate
            ;;
        hosts)
            cmd_hosts
            ;;
        nginx)
            cmd_nginx
            ;;
        mode)
            cmd_mode
            ;;
        config)
            cmd_show_config
            ;;
        completion)
            cmd_completion
            ;;
        help|"")
            usage
            ;;
        *)
            error "Unknown command: $COMMAND"
            usage
            exit 1
            ;;
    esac
}

# Command: Create domain
cmd_create_domain() {
    # Override proxy mode if specified
    if [[ -n "$FORCE_MODE" ]]; then
        export PROXY_MODE="$FORCE_MODE"
    fi

    # Override template if specified
    if [[ -n "$CUSTOM_TEMPLATE" ]]; then
        export CUSTOM_TEMPLATE_PATH="$CUSTOM_TEMPLATE"
    fi

    if [[ -z "$HOST" ]]; then
        read -p "Enter domain name: " HOST
    fi

    if [[ -z "$HOST" ]]; then
        error "Domain is required"
        exit 1
    fi

    # SSL cert installation writes to system trust store — requires root.
    # Skip this check for subdomains: they reuse the parent cert (no new cert generated).
    if [[ "$SSL_ENABLED" == "true" ]] && ! $IS_SUBDOMAIN && ! check_root; then
        warning "SSL certificate installation requires root privileges"
        info "Re-running with sudo..."
        exec sudo "$0" "${_ORIG_ARGS[@]}"
    fi

    # Route to static handler when --static flag is set
    if $IS_STATIC; then
        _cmd_create_static_domain
        return
    fi

    if [[ -z "$PORT" ]]; then
        read -p "Enter port number: " PORT
    fi

    if [[ -z "$PORT" ]]; then
        error "Port is required"
        exit 1
    fi

    # Determine certificate domain
    local cert_domain="$HOST"
    if $IS_SUBDOMAIN && [[ -n "$MAIN_DOMAIN" ]]; then
        cert_domain="$MAIN_DOMAIN"
        info "Using main domain certificate: $cert_domain"
    fi

    # Show configuration
    info "Creating domain: $HOST"
    info "Port: $PORT"
    info "IP: $IP"
    info "SSL Enabled: $SSL_ENABLED"
    info "Proxy Mode: $(determine_proxy_mode)"

    # Generate certificate if SSL is enabled
    if [[ "$SSL_ENABLED" == "true" ]]; then
        info "Certificate domain: $cert_domain"

        if $IS_SUBDOMAIN && [[ -n "$MAIN_DOMAIN" ]]; then
            info "Subdomain: reusing existing certificate for $cert_domain"
        elif [[ -f "${CERT_DIR}/${cert_domain}.crt" ]]; then
            warning "Certificate already exists for: $cert_domain"
            if ! confirm "Regenerate certificate?"; then
                info "Using existing certificate"
            else
                if ! generate_certificate "$cert_domain"; then
                    error "Failed to generate certificate"
                    exit 1
                fi
            fi
        else
            if ! generate_certificate "$cert_domain"; then
                error "Failed to generate certificate"
                exit 1
            fi
        fi
    else
        info "Skipping certificate generation (SSL disabled)"
    fi

    # Create nginx configuration
    if ! create_site_config "$HOST" "$PORT" "$cert_domain" "$SSL_ENABLED"; then
        error "Failed to create site configuration"
        exit 1
    fi

    # Add to hosts file (uses sudo tee automatically if not root)
    if ! add_host "$IP" "$HOST"; then
        warning "Hosts file not updated — run: sudo devproxy hosts add -h $HOST"
    fi

    local scheme="http"
    [[ "$SSL_ENABLED" == "true" ]] && scheme="https"

    echo ""
    echo -e "  ${COLOR_GREEN}╭─ Domain Ready ──────────────────────────────────────────╮${COLOR_RESET}"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}  ${COLOR_WHITE}${HOST}${COLOR_RESET} is set up successfully"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}  ${COLOR_DIM}URL:${COLOR_RESET}  ${COLOR_CYAN}${scheme}://${HOST}${COLOR_RESET}"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}  ${COLOR_DIM}Port:${COLOR_RESET} ${PORT}  ${COLOR_DIM}|  Mode:${COLOR_RESET} $(determine_proxy_mode 2>/dev/null || echo 'N/A')  ${COLOR_DIM}|  SSL:${COLOR_RESET} ${SSL_ENABLED}"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}"
    echo -e "  ${COLOR_GREEN}╰─────────────────────────────────────────────────────────╯${COLOR_RESET}"
    echo ""
}

# Internal: handle static domain creation (called from cmd_create_domain when --static)
_cmd_create_static_domain() {
    # --name myapp  →  /srv/static/myapp  (shorthand for ecosystem/Docker mode)
    if [[ -z "$STATIC_ROOT" && -n "$STATIC_APP_NAME" ]]; then
        STATIC_ROOT="/srv/static/${STATIC_APP_NAME}"
    fi

    if [[ -z "$STATIC_ROOT" ]]; then
        read -p "Enter static root directory (or app name for /srv/static/<name>): " STATIC_ROOT
        # Allow bare names like "myapp" to expand to /srv/static/myapp
        if [[ -n "$STATIC_ROOT" && "$STATIC_ROOT" != /* ]]; then
            STATIC_ROOT="/srv/static/${STATIC_ROOT}"
        fi
    fi

    if [[ -z "$STATIC_ROOT" ]]; then
        error "Static root directory is required (--root PATH or --name APP)"
        exit 1
    fi

    # Determine certificate domain
    local cert_domain="$HOST"
    if $IS_SUBDOMAIN && [[ -n "$MAIN_DOMAIN" ]]; then
        cert_domain="$MAIN_DOMAIN"
        info "Using main domain certificate: $cert_domain"
    fi

    info "Creating static domain: $HOST"
    info "Root: $STATIC_ROOT"
    info "IP: $IP"
    info "SSL Enabled: $SSL_ENABLED"

    # Generate certificate if SSL is enabled
    if [[ "$SSL_ENABLED" == "true" ]]; then
        info "Certificate domain: $cert_domain"

        if $IS_SUBDOMAIN && [[ -n "$MAIN_DOMAIN" ]]; then
            info "Subdomain: reusing existing certificate for $cert_domain"
        elif [[ -f "${CERT_DIR}/${cert_domain}.crt" ]]; then
            warning "Certificate already exists for: $cert_domain"
            if ! confirm "Regenerate certificate?"; then
                info "Using existing certificate"
            else
                if ! generate_certificate "$cert_domain"; then
                    error "Failed to generate certificate"
                    exit 1
                fi
            fi
        else
            if ! generate_certificate "$cert_domain"; then
                error "Failed to generate certificate"
                exit 1
            fi
        fi
    else
        info "Skipping certificate generation (SSL disabled)"
    fi

    # Create static nginx configuration
    if ! create_static_config "$HOST" "$STATIC_ROOT" "$cert_domain" "$SSL_ENABLED"; then
        error "Failed to create static site configuration"
        exit 1
    fi

    # Add to hosts file (uses sudo automatically if not root)
    if ! add_host "$IP" "$HOST"; then
        warning "Hosts file not updated — run: sudo devproxy hosts add -h $HOST"
    fi

    local scheme="http"
    [[ "$SSL_ENABLED" == "true" ]] && scheme="https"

    echo ""
    echo -e "  ${COLOR_GREEN}╭─ Static Site Ready ─────────────────────────────────────╮${COLOR_RESET}"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}  ${COLOR_WHITE}${HOST}${COLOR_RESET} is set up successfully"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}  ${COLOR_DIM}URL:${COLOR_RESET}   ${COLOR_CYAN}${scheme}://${HOST}${COLOR_RESET}"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}  ${COLOR_DIM}Root:${COLOR_RESET}  ${STATIC_ROOT}"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}  ${COLOR_DIM}Mode:${COLOR_RESET}  $(determine_proxy_mode 2>/dev/null || echo 'N/A')  ${COLOR_DIM}|  SSL:${COLOR_RESET} ${SSL_ENABLED}"
    echo -e "  ${COLOR_GREEN}│${COLOR_RESET}"
    echo -e "  ${COLOR_GREEN}╰─────────────────────────────────────────────────────────╯${COLOR_RESET}"
    echo ""
}

# Command: Remove domain
cmd_remove_domain() {
    if [[ -z "$HOST" ]]; then
        read -p "Enter domain name to remove: " HOST
    fi

    if [[ -z "$HOST" ]]; then
        error "Domain is required"
        exit 1
    fi

    info "Removing domain: $HOST"

    if ! confirm "Are you sure you want to remove $HOST?"; then
        info "Operation cancelled"
        exit 0
    fi

    # Remove nginx configuration
    remove_site_config "$HOST"

    # Ask about certificate removal
    if [[ -f "${CERT_DIR}/${HOST}.crt" ]]; then
        if confirm "Remove SSL certificate for $HOST?"; then
            remove_certificate "$HOST"
        fi
    fi

    # Remove from hosts file (uses sudo automatically if not root)
    if confirm "Remove from hosts file?"; then
        if ! remove_host "$HOST"; then
            warning "Hosts file not updated — run: sudo devproxy hosts remove -h $HOST"
        fi
    fi

    success "Domain removed successfully: $HOST"
}

# Command: Update devproxy
cmd_update() {
    local repo="mohamadtsn/local-dev-proxy"
    local current_version
    current_version=$(cat "${BASE_DIR}/VERSION" 2>/dev/null || echo "dev")

    if ! command_exists curl && ! command_exists wget; then
        error "curl or wget is required to check for updates"
        exit 1
    fi

    info "Checking for updates..."

    local latest_tag=""
    if command_exists curl; then
        latest_tag=$(curl -fsSL "https://api.github.com/repos/${repo}/releases/latest" \
            2>/dev/null | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')
    else
        latest_tag=$(wget -qO- "https://api.github.com/repos/${repo}/releases/latest" \
            2>/dev/null | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')
    fi

    if [[ -z "$latest_tag" ]]; then
        error "Failed to fetch latest version from GitHub"
        exit 1
    fi

    local latest_version="${latest_tag#v}"

    if [[ "$current_version" == "$latest_version" ]]; then
        success "Already up to date: v${current_version}"
        exit 0
    fi

    echo ""
    echo -e "  ${COLOR_CYAN}╭─ Update Available ──────────────────────────────────────╮${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}│${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}│${COLOR_RESET}  ${COLOR_DIM}Installed:${COLOR_RESET}  ${COLOR_WHITE}v${current_version}${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}│${COLOR_RESET}  ${COLOR_DIM}Available:${COLOR_RESET}  ${COLOR_GREEN}v${latest_version}${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}│${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}╰─────────────────────────────────────────────────────────╯${COLOR_RESET}"
    echo ""

    if ! confirm "Update devproxy to v${latest_version}?"; then
        info "Update cancelled"
        exit 0
    fi

    local install_script="${BASE_DIR}/scripts/install.sh"
    if [[ ! -f "$install_script" ]]; then
        error "Install script not found: $install_script"
        exit 1
    fi

    if [[ $EUID -ne 0 ]]; then
        exec sudo bash "$install_script" --yes
    else
        bash "$install_script" --yes
    fi
}

# Command: Certificate management
cmd_certificate() {
    case "$SUBCOMMAND" in
        generate)
            if [[ -z "$HOST" ]]; then
                read -p "Enter domain name: " HOST
            fi
            generate_certificate "$HOST"
            ;;
        remove)
            if [[ -z "$HOST" ]]; then
                read -p "Enter domain name: " HOST
            fi
            if confirm "Remove certificate for $HOST?"; then
                remove_certificate "$HOST"
            fi
            ;;
        list)
            list_certificates
            ;;
        *)
            error "Unknown certificate subcommand: $SUBCOMMAND"
            echo "Available subcommands: generate, remove, list"
            exit 1
            ;;
    esac
}

# Command: Hosts management
cmd_hosts() {
    case "$SUBCOMMAND" in
        add)
            if [[ -z "$HOST" ]]; then
                read -p "Enter hostname: " HOST
            fi
            add_host "$IP" "$HOST"
            ;;
        remove)
            if [[ -z "$HOST" ]]; then
                read -p "Enter hostname or IP: " HOST
            fi
            if confirm "Remove $HOST from hosts file?"; then
                remove_host "$HOST"
            fi
            ;;
        list)
            list_hosts
            ;;
        *)
            manage_hosts
            ;;
    esac
}

# Command: Nginx management
cmd_nginx() {
    case "$SUBCOMMAND" in
        create-site)
            if [[ -z "$HOST" ]]; then
                read -p "Enter domain name: " HOST
            fi
            if [[ -z "$PORT" ]]; then
                read -p "Enter port number: " PORT
            fi

            # Ask about SSL
            if confirm "Enable SSL for this site?" "y"; then
                SSL_ENABLED=true
            else
                SSL_ENABLED=false
            fi

            create_site_config "$HOST" "$PORT" "$HOST" "$SSL_ENABLED"
            ;;
        create-static)
            if [[ -z "$HOST" ]]; then
                read -p "Enter domain name: " HOST
            fi

            # --name myapp  →  /srv/static/myapp  (shorthand for ecosystem/Docker mode)
            if [[ -z "$STATIC_ROOT" && -n "$STATIC_APP_NAME" ]]; then
                STATIC_ROOT="/srv/static/${STATIC_APP_NAME}"
            fi

            if [[ -z "$STATIC_ROOT" ]]; then
                read -p "Enter static root directory (or app name for /srv/static/<name>): " STATIC_ROOT
                if [[ -n "$STATIC_ROOT" && "$STATIC_ROOT" != /* ]]; then
                    STATIC_ROOT="/srv/static/${STATIC_ROOT}"
                fi
            fi

            if [[ -z "$STATIC_ROOT" ]]; then
                error "Static root directory is required (--root PATH or --name APP)"
                exit 1
            fi

            # Ask about SSL
            if confirm "Enable SSL for this static site?" "y"; then
                SSL_ENABLED=true
            else
                SSL_ENABLED=false
            fi

            create_static_config "$HOST" "$STATIC_ROOT" "$HOST" "$SSL_ENABLED"
            ;;
        remove-site)
            if [[ -z "$HOST" ]]; then
                read -p "Enter domain name: " HOST
            fi
            if confirm "Remove site configuration for $HOST?"; then
                remove_site_config "$HOST"
            fi
            ;;
        list)
            list_site_configs
            ;;
        test)
            test_nginx_config
            ;;
        reload)
            reload_nginx
            ;;
        *)
            error "Unknown nginx subcommand: $SUBCOMMAND"
            echo "Available subcommands: create-site, create-static, remove-site, list, test, reload"
            exit 1
            ;;
    esac
}

# Command: Mode management
cmd_mode() {
    if [[ -n "$FORCE_MODE" ]]; then
        case "$FORCE_MODE" in
            docker|local|auto)
                local config_file="$HOME/.local-dev-proxy.conf"
                if [[ -f "$config_file" ]]; then
                    sed -i.bak "s/^export PROXY_MODE=.*/export PROXY_MODE=\"$FORCE_MODE\"/" "$config_file"
                else
                    echo "export PROXY_MODE=\"$FORCE_MODE\"" > "$config_file"
                fi
                echo ""
                echo -e "  ${COLOR_GREEN}✓${COLOR_RESET}  Proxy mode set to ${COLOR_CYAN}${FORCE_MODE}${COLOR_RESET}"
                echo -e "  ${COLOR_DIM}Takes effect for new commands.${COLOR_RESET}"
                echo ""
                ;;
            *)
                echo ""
                echo -e "  ${COLOR_RED}✗  Invalid mode: ${FORCE_MODE}${COLOR_RESET}"
                echo -e "  ${COLOR_DIM}Valid modes: docker, local, auto${COLOR_RESET}"
                echo ""
                exit 1
                ;;
        esac
        return
    fi

    # Show current status
    local current_mode
    current_mode=$(determine_proxy_mode 2>/dev/null || echo "unavailable")

    local docker_status local_status
    if is_docker_available 2>/dev/null && is_docker_container_running "$DOCKER_CONTAINER_NAME" 2>/dev/null; then
        docker_status="${COLOR_GREEN}● running${COLOR_RESET}"
    elif is_docker_available 2>/dev/null; then
        docker_status="${COLOR_YELLOW}● available${COLOR_RESET} ${COLOR_DIM}(container not running)${COLOR_RESET}"
    else
        docker_status="${COLOR_DIM}○ not available${COLOR_RESET}"
    fi

    if command_exists "$NGINX_BIN" 2>/dev/null; then
        local_status="${COLOR_GREEN}● installed${COLOR_RESET}"
    else
        local_status="${COLOR_DIM}○ not installed${COLOR_RESET}"
    fi

    echo ""
    echo -e "  ${COLOR_CYAN}╭─ Proxy Mode ──────────────────────────────────────────╮${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}│${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}│${COLOR_RESET}  Configured:      ${COLOR_BOLD}${PROXY_MODE}${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}│${COLOR_RESET}  Active:          ${COLOR_BOLD}${current_mode}${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}│${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}╰───────────────────────────────────────────────────────╯${COLOR_RESET}"
    echo ""
    echo -e "  ${COLOR_BOLD}Available Modes${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}docker${COLOR_RESET}    Use Docker container for Nginx      ${docker_status}"
    echo -e "  ${COLOR_CYAN}local${COLOR_RESET}     Use system Nginx installation        ${local_status}"
    echo -e "  ${COLOR_CYAN}auto${COLOR_RESET}      Auto-detect ${COLOR_DIM}(prefer Docker if available)${COLOR_RESET}"
    echo ""
    echo -e "  ${COLOR_DIM}To change:  devproxy mode --mode <docker|local|auto>${COLOR_RESET}"
    echo ""
}

# Command: Show configuration
cmd_show_config() {
    local current_mode
    current_mode=$(determine_proxy_mode 2>/dev/null || echo "N/A")

    local version
    version=$(cat "${BASE_DIR}/VERSION" 2>/dev/null || echo "dev")

    local docker_running
    is_docker_container_running "$DOCKER_CONTAINER_NAME" 2>/dev/null \
        && docker_running="${COLOR_GREEN}Running${COLOR_RESET}" \
        || docker_running="${COLOR_RED}Not Running${COLOR_RESET}"

    local nginx_installed
    command_exists "$NGINX_BIN" \
        && nginx_installed="${COLOR_GREEN}Installed${COLOR_RESET}" \
        || nginx_installed="${COLOR_RED}Not Installed${COLOR_RESET}"

    local user_conf_exists
    [[ -f "$HOME/.local-dev-proxy.conf" ]] \
        && user_conf_exists="${COLOR_GREEN}Yes${COLOR_RESET}" \
        || user_conf_exists="${COLOR_YELLOW}No${COLOR_RESET}"

    echo ""
    echo -e "  ${COLOR_CYAN}╭──────────────────────────────────────────────────────╮${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}│${COLOR_RESET}  ${COLOR_WHITE}Local Dev Proxy${COLOR_RESET}  ${COLOR_DIM}·${COLOR_RESET}  Configuration  ${COLOR_DIM}·${COLOR_RESET}  ${COLOR_YELLOW}v${version}${COLOR_RESET}      ${COLOR_CYAN}│${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}╰──────────────────────────────────────────────────────╯${COLOR_RESET}"
    echo ""

    echo -e "  ${COLOR_BOLD}General${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "  Base Directory    $BASE_DIR"
    echo -e "  Proxy Mode        ${COLOR_CYAN}${PROXY_MODE}${COLOR_RESET}  ${COLOR_DIM}(active: ${current_mode})${COLOR_RESET}"
    echo -e "  Auto Reload       $AUTO_RELOAD"
    echo -e "  Backup Configs    $BACKUP_CONFIGS"
    echo ""

    echo -e "  ${COLOR_BOLD}Directories${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "  Certificates      $CERT_DIR"
    echo -e "  Sites Enabled     $SITE_ENABLED_DIR"
    echo -e "  Templates         $TEMPLATE_DIR"
    echo -e "  Libraries         $LIB_DIR"
    echo ""

    echo -e "  ${COLOR_BOLD}Docker${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "  Container Name    $DOCKER_CONTAINER_NAME"
    echo -e "  Host Access       $DOCKER_HOST_ACCESS"
    echo -e "  SSL Path          $DOCKER_SSL_PATH"
    echo -e "  Config Path       $DOCKER_CONF_PATH"
    echo -e "  Status            $(echo -e "$docker_running")"
    echo ""

    echo -e "  ${COLOR_BOLD}Local Nginx${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "  Config Dir        $NGINX_CONF_DIR"
    echo -e "  Enabled Dir       $NGINX_ENABLED_DIR"
    echo -e "  SSL Dir           $NGINX_SSL_DIR"
    echo -e "  Binary            $NGINX_BIN"
    echo -e "  Use Systemd       $USE_SYSTEMD"
    echo -e "  Status            $(echo -e "$nginx_installed")"
    echo ""

    echo -e "  ${COLOR_BOLD}SSL Certificate${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "  Country           $SSL_COUNTRY"
    echo -e "  State             $SSL_STATE"
    echo -e "  City              $SSL_CITY"
    echo -e "  Organization      $SSL_ORGANIZATION"
    echo -e "  Email             $SSL_EMAIL"
    echo -e "  Validity Days     $SSL_VALIDITY_DAYS"
    echo -e "  Key Size          $SSL_KEY_SIZE bits"
    echo ""

    echo -e "  ${COLOR_BOLD}System${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "  OS                $(detect_os)"
    echo -e "  Hosts File        $HOSTS_FILE"
    echo -e "  Log File          $LOG_FILE"
    echo -e "  Default IP        $DEFAULT_IP"
    echo -e "  SSL Default       $DEFAULT_SSL_ENABLED"
    echo ""

    echo -e "  ${COLOR_BOLD}Ecosystem (public-services)${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    if is_ecosystem_active 2>/dev/null; then
        echo -e "  Status            ${COLOR_GREEN}● detected${COLOR_RESET}  ${COLOR_DIM}(volume-mounted, no docker cp)${COLOR_RESET}"
        echo -e "  Conf Dir          ${ECOSYSTEM_CONF_DIR:-}"
        echo -e "  SSL Dir           ${ECOSYSTEM_SSL_DIR:-}"
    else
        echo -e "  Status            ${COLOR_DIM}○ not detected${COLOR_RESET}"
        echo -e "  ${COLOR_DIM}Set ECOSYSTEM_AUTO_DETECT=false to disable detection.${COLOR_RESET}"
    fi
    echo ""

    echo -e "  ${COLOR_BOLD}User Config${COLOR_RESET}"
    echo -e "  ${COLOR_DIM}──────────────────────────────────────────────────────${COLOR_RESET}"
    echo -e "  Location          ~/.local-dev-proxy.conf"
    echo -e "  Exists            $(echo -e "$user_conf_exists")"
    echo ""
    echo -e "  ${COLOR_DIM}To override settings, edit: ${COLOR_CYAN}~/.local-dev-proxy.conf${COLOR_RESET}"
    echo ""
}

# Command: Output shell completion script
cmd_completion() {
    local shell="${SUBCOMMAND:-}"

    if [[ -z "$shell" ]]; then
        echo ""
        echo -e "  ${COLOR_BOLD}Usage:${COLOR_RESET}  devproxy completion ${COLOR_CYAN}<shell>${COLOR_RESET}"
        echo ""
        echo -e "  Supported shells: ${COLOR_CYAN}bash  zsh  fish${COLOR_RESET}"
        echo ""
        echo -e "  ${COLOR_BOLD}Install examples:${COLOR_RESET}"
        echo -e "    ${COLOR_DIM}# Bash — add to ~/.bashrc:${COLOR_RESET}"
        echo -e "    source <(devproxy completion bash)"
        echo ""
        echo -e "    ${COLOR_DIM}# Zsh — add to ~/.zshrc (fpath must include the dir):${COLOR_RESET}"
        echo -e "    devproxy completion zsh > \"\${fpath[1]}/_devproxy\""
        echo ""
        echo -e "    ${COLOR_DIM}# Fish:${COLOR_RESET}"
        echo -e "    devproxy completion fish > ~/.config/fish/completions/devproxy.fish"
        echo ""
        return 0
    fi

    local completion_dir="${BASE_DIR}/completion"

    case "$shell" in
        bash)
            if [[ -f "${completion_dir}/devproxy.bash" ]]; then
                cat "${completion_dir}/devproxy.bash"
            else
                error "Bash completion file not found: ${completion_dir}/devproxy.bash"
                return 1
            fi
            ;;
        zsh)
            if [[ -f "${completion_dir}/_devproxy" ]]; then
                cat "${completion_dir}/_devproxy"
            else
                error "Zsh completion file not found: ${completion_dir}/_devproxy"
                return 1
            fi
            ;;
        fish)
            if [[ -f "${completion_dir}/devproxy.fish" ]]; then
                cat "${completion_dir}/devproxy.fish"
            else
                error "Fish completion file not found: ${completion_dir}/devproxy.fish"
                return 1
            fi
            ;;
        *)
            error "Unknown shell: $shell"
            echo "Supported shells: bash, zsh, fish"
            return 1
            ;;
    esac
}

# Main execution
main() {
    _ORIG_ARGS=("$@")
    parse_args "$@"
    execute_command
}

main "$@"